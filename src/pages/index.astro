---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Mahesh Kumar – AI, Data & Product Leader">
  <section class="py-24 md:py-32">
    <div class="mx-auto grid max-w-5xl items-center gap-12 px-6 md:grid-cols-2">
      <!-- Photo -->
      <div class="flex justify-center md:justify-start">
        <div class="relative">
          <!-- subtle glow behind -->
          <div
            class="absolute inset-0 -z-10 rounded-full bg-primary/20 blur-2xl"
            aria-hidden="true"
          />
          <img
            src="/mahesh-kumar.jpg"
            alt="Mahesh Kumar"
            class="h-60 w-60 md:h-72 md:w-72 rounded-full object-cover shadow-2xl ring-2 ring-primary/40
                   transition duration-300 ease-out hover:scale-105 hover:ring-primary/70"
            loading="eager"
          />
        </div>
      </div>

      <!-- Text -->
      <div class="text-center md:text-left">
        <p class="text-sm font-semibold tracking-tight text-white/70 mb-3">
          Mahesh Kumar
        </p>

        <h1 class="text-5xl md:text-6xl font-bold tracking-tight text-white mb-6">
          AI, Data & Product Leader
        </h1>

        <p class="text-xl text-white/80 mb-4">
          Building insight-driven AI products for financial services and risk-driven organizations.
        </p>

        <p class="text-lg text-white/70 mb-10">
          17+ years turning complex business and risk problems into scalable, measurable AI-enabled products.
        </p>

        <div class="flex flex-col sm:flex-row items-center gap-4 justify-center md:justify-start">
          <a
            href="/projects"
            class="inline-flex items-center justify-center rounded-full bg-primary px-7 py-3 text-base font-medium text-white
                   hover:opacity-90 transition"
          >
            View My Work
          </a>

          <a
            href="/about"
            class="inline-flex items-center justify-center rounded-full bg-white/10 px-7 py-3 text-base font-medium text-white
                   ring-1 ring-white/15 hover:bg-white/15 transition"
          >
            About Me
          </a>
        </div>
      </div>

    </div>
  </section>

  <!-- Core Skills Section -->
  <section class="mt-24 mb-16 max-w-5xl mx-auto px-6">
    <h2 class="text-2xl font-semibold text-white mb-6 text-center md:text-left">
      Core Skills
    </h2>

    <div class="flex flex-wrap gap-3 justify-center md:justify-start">
      <span class="px-4 py-2 bg-white/10 text-white/90 rounded-full">Product Strategy</span>
      <span class="px-4 py-2 bg-white/10 text-white/90 rounded-full">GenAI Copilots</span>
      <span class="px-4 py-2 bg-white/10 text-white/90 rounded-full">Machine Learning</span>
      <span class="px-4 py-2 bg-white/10 text-white/90 rounded-full">Data Governance</span>
      <span class="px-4 py-2 bg-white/10 text-white/90 rounded-full">Python</span>
      <span class="px-4 py-2 bg-white/10 text-white/90 rounded-full">SQL</span>
    </div>
  </section>

</Layout>
