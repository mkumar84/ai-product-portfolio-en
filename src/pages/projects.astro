---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Projects – Mahesh Kumar">
  <section class="py-20 max-w-6xl mx-auto px-6">
    <h1 class="text-4xl font-bold mb-12 text-white">Featured Projects</h1>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      <div class="p-6 bg-white rounded-xl shadow hover:shadow-lg transition">
        <h3 class="text-xl font-semibold mb-3 text-gray-900">
          GenAI Next Best Action & Claims Summarization
        </h3>
        <p class="text-gray-700 mb-4">
          Launched GenAI-enabled decision-support tools using agentic RAG architecture, improving adjuster efficiency and enabling a $3M reserve release.
        </p>
        <a
          href="https://github.com/mkumar84/Claim-Summarization-AI"
          target="_blank"
          rel="noopener noreferrer"
          class="text-blue-700 font-medium hover:underline"
        >
          View Repo →
        </a>
      </div>

      <div class="p-6 bg-white rounded-xl shadow hover:shadow-lg transition">
        <h3 class="text-xl font-semibold mb-3 text-gray-900">Insurance Analytics Dashboard</h3>
        <p class="text-gray-700 mb-4">
          Interactive dashboard consolidating claims, loss ratios, and operational KPIs for underwriting, claims, and risk teams.
        </p>
        <a
          href="https://github.com/mkumar84/Insurance_Dashboard"
          target="_blank"
          rel="noopener noreferrer"
          class="text-blue-700 font-medium hover:underline"
        >
          View Repo →
        </a>
      </div>

      <div class="p-6 bg-white rounded-xl shadow hover:shadow-lg transition">
        <h3 class="text-xl font-semibold mb-3 text-gray-900">Bankruptcy Prediction Model</h3>
        <p class="text-gray-700 mb-4">
          ML model predicting financial distress using financial ratios and behavioral indicators to support proactive risk management.
        </p>
        <a
          href="https://github.com/mkumar84/Bankuptcy-Prediction"
          target="_blank"
          rel="noopener noreferrer"
          class="text-blue-700 font-medium hover:underline"
        >
          View Repo →
        </a>
      </div>

      <div class="p-6 bg-white rounded-xl shadow hover:shadow-lg transition">
        <h3 class="text-xl font-semibold mb-3 text-gray-900">AI Data Discovery Assistant</h3>
        <p class="text-gray-700 mb-4">
          LLM-powered assistant enabling natural-language search and explanation of enterprise data assets using metadata and embeddings.
        </p>
        <a
          href="https://github.com/mkumar84/mkumar84-AI-Data-Discovery-Assistance"
          target="_blank"
          rel="noopener noreferrer"
          class="text-blue-700 font-medium hover:underline"
        >
          View Repo →
        </a>
      </div>

      <div class="p-6 bg-white rounded-xl shadow hover:shadow-lg transition">
        <h3 class="text-xl font-semibold mb-3 text-gray-900">AI Movie Production Agent</h3>
        <p class="text-gray-700 mb-4">
          LLM-powered creative assistant generating scenes, characters, dialogues, and production notes for film ideation.
        </p>
        <a
          href="https://github.com/mkumar84/ai_movie_production_agent"
          target="_blank"
          rel="noopener noreferrer"
          class="text-blue-700 font-medium hover:underline"
        >
          View Repo →
        </a>
      </div>
    </div>
  </section>
</Layout>
