---
import Footer from "@components/Footer.astro";
import { SITE_CONFIG } from "@config";

// IMPORTANT: load your global styles (Tailwind)
import "../styles/global.css";

const {
  title,
  description,
  lang,
  author,
  socialLinks,
  canonicalURL = new URL(Astro.url.pathname, Astro.site).href,
} = SITE_CONFIG;
---

<!doctype html>
<html lang={lang ?? "en"}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="canonical" href={canonicalURL} />
  </head>

  <body class="min-h-screen bg-black text-white">
    <header class="sticky top-0 z-50 border-b border-white/10 bg-black/70 backdrop-blur">
      <nav class="mx-auto flex max-w-5xl items-center justify-between px-5 py-4">
        <a href="/" class="text-sm font-semibold tracking-tight">
          {author}
        </a>

        <div class="flex items-center gap-4 text-sm text-white/80">
          <a class="hover:text-white" href="/#experience">Experience</a>
          <a class="hover:text-white" href="/projects">Projects</a>
          <a class="hover:text-white" href="/about">About</a>
        </div>
      </nav>
    </header>

    <main class="mx-auto max-w-5xl px-5 py-10">
      <slot />
    </main>

    <footer class="mx-auto max-w-5xl px-5 pb-10">
      <Footer author={author} socialLinks={socialLinks} />
    </footer>
  </body>
</html>
