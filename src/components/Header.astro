---
import { Icon } from "astro-icon";
---

<header class="w-full border-b border-gray-200 bg-white/80 backdrop-blur-md sticky top-0 z-50">
  <nav class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    
    <!-- Logo -->
    <a href="/" class="text-xl font-semibold text-gray-900">
      MK
    </a>

    <!-- Desktop Navigation -->
    <div class="hidden md:flex space-x-8 text-gray-700 font-medium">
      <a href="/" class="hover:text-black transition">Home</a>
      <a href="/about" class="hover:text-black transition">About</a>
      <a href="/projects" class="hover:text-black transition">Projects</a>
      <a href="/skills" class="hover:text-black transition">Skills</a>
      <a href="/contact" class="hover:text-black transition">Contact</a>
    </div>

    <!-- Mobile Menu Button -->
    <button id="mobile-menu-button" class="md:hidden text-gray-700">
      <Icon name="heroicons:bars-3" class="w-7 h-7" />
    </button>
  </nav>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="md:hidden hidden px-6 pb-4 space-y-3 text-gray-700 font-medium">
    <a href="/" class="block hover:text-black transition">Home</a>
    <a href="/about" class="block hover:text-black transition">About</a>
    <a href="/projects" class="block hover:text-black transition">Projects</a>
    <a href="/skills" class="block hover:text-black transition">Skills</a>
    <a href="/contact" class="block hover:text-black transition">Contact</a>
  </div>

  <script>
    const btn = document.getElementById("mobile-menu-button");
    const menu = document.getElementById("mobile-menu");

    btn.addEventListener("click", () => {
      menu.classList.toggle("hidden");
    });
  </script>
</header>
