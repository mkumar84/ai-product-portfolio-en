---
/**
 * Header.astro (no astro-icon)
 * - Mobile menu toggle (safe null checks)
 * - Dark mode toggle (desktop + mobile) with persistence
 * - Active link highlighting using Astro.url.pathname
 */
const current = Astro.url.pathname;
---

<header class="w-full border-b border-gray-200 dark:border-gray-700 bg-white/80 dark:bg-gray-900/80 backdrop-blur-md sticky top-0 z-50">
  <nav class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">

    <!-- Left: Logo + Profile Photo -->
    <div class="flex items-center space-x-3">
      <img
        src="/Mahesh%20Kumar_01-min.jpg"
        alt="Mahesh Kumar"
        class="w-10 h-10 rounded-full object-cover border border-gray-300 dark:border-gray-600"
      />
      <a href="/" class="text-xl font-semibold text-gray-900 dark:text-white">
        MK
      </a>
    </div>

    <!-- Desktop Navigation -->
    <div class="hidden md:flex items-center space-x-8 text-gray-700 dark:text-gray-300 font-medium">

      <a href="/" class={`hover:text-black dark:hover:text-white transition ${current === "/" ? "font-semibold underline" : ""}`}>
        Home
      </a>

      <a href="/about" class={`hover:text-black dark:hover:text-white transition ${current === "/about" ? "font-semibold underline" : ""}`}>
        About
      </a>

      <a href="/projects" class={`hover:text-black dark:hover:text-white transition ${current === "/projects" ? "font-semibold underline" : ""}`}>
        Projects
      </a>

      <a href="/skills" class={`hover:text-black dark:hover:text-white transition ${current === "/skills" ? "font-semibold underline" : ""}`}>
        Skills
      </a>

      <a href="/contact" class={`hover:text-black dark:hover:text-white transition ${current === "/contact" ? "font-semibold underline" : ""}`}>
        Contact
      </a>

      <!-- Dark Mode Toggle (Desktop) -->
      <button
        id="theme-toggle"
        type="button"
        class="ml-4 text-gray-700 dark:text-gray-300 hover:text-black dark:hover:text-white transition"
        aria-label="Toggle dark mode"
      >
        <!-- Moon (shown in dark mode) -->
        <svg class="w-6 h-6 hidden dark:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
        </svg>

        <!-- Sun (shown in light mode) -->
        <svg class="w-6 h-6 dark:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2m0 14v2m9-9h-2M5 12H3m15.364-6.364-1.414 1.414M7.05 16.95l-1.414 1.414m12.728 0-1.414-1.414M7.05 7.05 5.636 5.636" />
          <circle cx="12" cy="12" r="4" />
        </svg>
      </button>
    </div>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-button"
      type="button"
      class="md:hidden text-gray-700 dark:text-gray-300 hover:text-black dark:hover:text-white transition"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="md:hidden hidden px-6 pb-4 space-y-3 text-gray-700 dark:text-gray-300 font-medium"
  >
    <a href="/" class={`block hover:text-black dark:hover:text-white transition ${current === "/" ? "font-semibold underline" : ""}`}>
      Home
    </a>

    <a href="/about" class={`block hover:text-black dark:hover:text-white transition ${current === "/about" ? "font-semibold underline" : ""}`}>
      About
    </a>

    <a href="/projects" class={`block hover:text-black dark:hover:text-white transition ${current === "/projects" ? "font-semibold underline" : ""}`}>
      Projects
    </a>

    <a href="/skills" class={`block hover:text-black dark:hover:text-white transition ${current === "/skills" ? "font-semibold underline" : ""}`}>
      Skills
    </a>

    <a href="/contact" class={`block hover:text-black dark:hover:text-white transition ${current === "/contact" ? "font-semibold underline" : ""}`}>
      Contact
    </a>

    <!-- Dark Mode Toggle (Mobile) -->
    <button
      id="theme-toggle-mobile"
      type="button"
      class="pt-3 text-gray-700 dark:text-gray-300 hover:text-black dark:hover:text-white transition"
      aria-label="Toggle dark mode"
    >
      <!-- Moon (shown in dark mode) -->
      <svg class="w-6 h-6 hidden dark:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
      </svg>

      <!-- Sun (shown in light mode) -->
      <svg class="w-6 h-6 dark:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2m0 14v2m9-9h-2M5 12H3m15.364-6.364-1.414 1.414M7.05 16.95l-1.414 1.414m12.728 0-1.414-1.414M7.05 7.05 5.636 5.636" />
        <circle cx="12" cy="12" r="4" />
      </svg>
    </button>
  </div>

  <script is:inline>
    // --- Mobile menu toggle ---
    const mobileBtn = document.querySelector("#mobile-menu-button");
    const mobileMenu = document.querySelector("#mobile-menu");

    if (mobileBtn && mobileMenu) {
      mobileBtn.addEventListener("click", () => {
        mobileMenu.classList.toggle("hidden");
        const isOpen = !mobileMenu.classList.contains("hidden");
        mobileBtn.setAttribute("aria-expanded", String(isOpen));
      });
    }

    // --- Theme helpers ---
    const setTheme = (theme) => {
      if (theme === "dark") document.documentElement.classList.add("dark");
      else document.documentElement.classList.remove("dark");

      try { localStorage.theme = theme; } catch {}
    };

    const getInitialTheme = () => {
      try {
        if (localStorage.theme === "dark" || localStorage.theme === "light") return localStorage.theme;
      } catch {}
      return window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
    };

    // Apply theme on load
    setTheme(getInitialTheme());

    // Toggle buttons (desktop + mobile)
    const toggleButtons = [
      document.getElementById("theme-toggle"),
      document.getElementById("theme-toggle-mobile"),
    ].filter(Boolean);

    toggleButtons.forEach((el) => {
      el.addEventListener("click", () => {
        const next = document.documentElement.classList.contains("dark") ? "light" : "dark";
        setTheme(next);
      });
    });
  </script>
</header>
